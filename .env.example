# Local-development environment variables for the blink-lightning-gateway
# stack. Copy this file to `.env.local` and fill in any overrides.

# Postgres connection. Defaults to the dev/docker-compose.yml service.
PG_CON=postgres://postgres:postgres@localhost:5435/blink_lightning_gateway

# Path to ln-gateway.yml
BLINK_LIGHTNING_GATEWAY_CONFIG=ln-gateway.yml

# Tracing (optional). If empty, the gateway falls back to a
# JSON-formatted `tracing-subscriber` on stdout.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
